{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-process-exit": "error",
    "strict": ["error", "global"],
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-undef": "error",
    "no-dupe-else-if": "error",
    "no-dupe-args": "error",
    "no-dupe-keys": "error",
    "no-empty": "warn",
    "no-extra-semi": "error",
    "no-func-assign": "error",
    "no-import-assign": "error",
    "no-obj-calls": "error",
    "no-setter-return": "error",
    "no-unreachable": "error",
    "no-unused-labels": "error",
    "require-yield": "error",
    "use-isnan": "error",
    "valid-typeof": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "logs/"
  ]
}
